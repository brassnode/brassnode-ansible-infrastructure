# WireGuard client config for: {{ item.name }}
# Generated by Ansible — copy to your client device

[Interface]
# Replace PrivateKey with THIS CLIENT'S private key
PrivateKey = <PASTE_CLIENT_PRIVATE_KEY_HERE>
Address    = {{ item.allowed_ips | join(', ') }}
{% if wireguard_dns is defined and wireguard_dns | length > 0 %}
DNS        = {{ wireguard_dns | join(', ') }}
{% endif %}

[Peer]
PublicKey  = {{ wg_server_public_key }}
{% if wireguard_use_preshared_keys | bool and wg_psk_map is defined %}
PresharedKey = {{ wg_psk_map[item.name] }}
{% endif %}
Endpoint   = {{ wireguard_server_public_ip }}:{{ wireguard_port }}
AllowedIPs = {{ item.client_allowed_ips | default(wireguard_client_allowed_ips) | join(', ') }}
{% if wireguard_persistent_keepalive > 0 %}
PersistentKeepalive = {{ wireguard_persistent_keepalive }}
{% endif %}
